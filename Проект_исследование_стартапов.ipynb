      "source": [
        "#Создадим вспомогательный датасет, где для какждого сегмента рассчитаем границы IQR\n",
        "def lower(group):\n",
        "    q1 = group.quantile(0.25)\n",
        "    q3 = group.quantile(0.75)\n",
        "    iqr = q3 - q1\n",
        "    lower = max(q1 - 1.5 * iqr, 0)\n",
        "    return lower\n",
        "\n",
        "def upper(group):\n",
        "    q1 = group.quantile(0.25)\n",
        "    q3 = group.quantile(0.75)\n",
        "    iqr = q3 - q1\n",
        "    upper = q3 + 1.5 * iqr\n",
        "    return upper\n",
        "\n",
        "df_iqrs = df_i.groupby('market')['funding_total_usd'].agg([lower, upper])\n",
        "df_iqrs"
      ]
    },
