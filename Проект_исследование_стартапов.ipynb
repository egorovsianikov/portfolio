      "source": [
        "#Проверяем попадение funding_total_usd в промежуток IQR для каждой категории\n",
        "def is_outline(row, df):\n",
        "    seg_upper = df.loc[row['market'], 'upper']\n",
        "    seg_lower = df.loc[row['market'], 'lower']\n",
        "    if (row['funding_total_usd'] >= seg_lower) & (row['funding_total_usd'] <= seg_upper):\n",
        "        return 0\n",
        "    else:\n",
        "        return 1\n",
        "\n",
        "df_i['is_outline'] = df_i.apply(lambda row: is_outline(row, df_iqrs), axis=1)\n",
        "df_i"
      ]
    },
